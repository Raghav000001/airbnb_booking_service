generator client {
  provider = "prisma-client-js"
  url      = env("DATABASE_URL")
}

datasource db {
  provider = "mysql"
  }

model Booking {
  id            Int           @id @default(autoincrement())
  userId        Int
  hotelId       Int
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  bookingAmount Int
  status        BookingStatus
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}
